# openclaw-VAULT: API Key Configuration
#
# Copy this file to .env and fill in your keys:
#   cp .env.example .env
#
# IMPORTANT:
#   - Create SCOPED/RESTRICTED API keys for sandbox use only
#   - Set HARD SPENDING LIMITS on your provider dashboard
#   - Rotate keys regularly (especially after any security incident)
#   - Never commit .env to git (it's in .gitignore)
#
# These keys are injected by the mitmproxy sidecar (Path A).
# The OpenClaw container NEVER sees these values.

ANTHROPIC_API_KEY=sk-ant-api03-REPLACE-WITH-YOUR-KEY
OPENAI_API_KEY=sk-REPLACE-WITH-YOUR-KEY-OR-LEAVE-BLANK
